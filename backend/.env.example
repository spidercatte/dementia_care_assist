# DementiaCare Coach - Backend Environment Variables
# Copy this file to .env and fill in your details

# Gemini API Key (Required for multimodal analysis and reasoning)
# Get one from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Vertex AI Search — Guidelines (set after running scripts/deploy_vertex_search.sh)
VERTEX_SEARCH_PROJECT_ID=adi-researc
VERTEX_SEARCH_LOCATION=global
VERTEX_SEARCH_DATASTORE_ID=dementia-care-guidelines

# Vertex AI Search — Patient Profiles (set after running scripts/deploy_patient_search.sh)
VERTEX_PATIENT_DATASTORE_ID=dementia-care-patients

# App configuration
HOST=0.0.0.0
PORT=8000
CHROMA_DB_PATH=chroma_db
