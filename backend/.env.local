# Gemini API Key (Required for live multimodal analysis and reasoning)
# Get a free API key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Server Bind Address and Port
HOST=127.0.0.1
PORT=8000

# Local ChromaDB Vector Store persistence path
CHROMA_DB_PATH=chroma_db

# Optional Security / RBAC Keys (leave empty to bypass authentication checks)
ADMIN_API_KEY=
USER_API_KEY=
